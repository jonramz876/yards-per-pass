# Supabase (get from supabase.com → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database connection (get from supabase.com → project → Settings → Database → Connection string)
# Used by scripts/ingest.py and GitHub Actions
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ISR revalidation (generate a random secret, add to GitHub Actions secrets too)
REVALIDATE_SECRET=your-random-secret-here

# Site URL for GitHub Actions revalidation call (GitHub Actions secret: SITE_URL)
# SITE_URL=https://yardsperpass.com
